# Browser-exposed key for the Maps Embed API on /shop/[slug].
# Enable: Maps Embed API in Google Cloud Console.
# Restrict: HTTP referrers (your domain only).
# Cost: free for basic place embeds.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Absolute base URL used for Open Graph image resolution.
# Set this to your production URL when deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
